{
  "info": {
    "_postman_id": "suraksha-health-auth-collection",
    "name": "Suraksha-health Auth",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Auth endpoints for the Suraksha-health backend. Base URL: http://localhost:5000\n\nEach run generates a unique test email via the Register pre-request script, so the collection is safe to run repeatedly without cleaning the database."
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [""]
      }
    }
  ],
  "item": [
    {
      "name": "Register",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Generate a unique email + fixed password for this entire run.",
              "// Both are saved as env vars so Login, Duplicate Email, and",
              "// Wrong Password all target the same user created in this run.",
              "var ts = Date.now();",
              "pm.environment.set('testEmail',    'dev' + ts + '@surakshahealth.com');",
              "pm.environment.set('testPassword', 'Test@1234');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('response has accessToken', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json).to.have.property('accessToken');",
              "});",
              "",
              "var json = pm.response.json();",
              "if (json.accessToken) {",
              "    pm.environment.set('accessToken', json.accessToken);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\",\n  \"fullName\": \"Dev One\",\n  \"role\": \"patient\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "register"]
        },
        "description": "Registers a brand-new user each run.\nPre-request script sets testEmail (timestamp-based) and testPassword in the environment."
      }
    },
    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('response has accessToken', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json).to.have.property('accessToken');",
              "});",
              "",
              "var json = pm.response.json();",
              "if (json.accessToken) {",
              "    pm.environment.set('accessToken', json.accessToken);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "login"]
        }
      }
    },
    {
      "name": "Get Me",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('response has user.email', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json).to.have.property('user');",
              "    pm.expect(json.user).to.have.property('email');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/me",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "me"]
        }
      }
    },
    {
      "name": "Refresh Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('response has new accessToken', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json).to.have.property('accessToken');",
              "});",
              "",
              "var json = pm.response.json();",
              "if (json.accessToken) {",
              "    pm.environment.set('accessToken', json.accessToken);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": ""
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/refresh-token",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "refresh-token"]
        },
        "description": "Uses the httpOnly refreshToken cookie set by Login — no body required."
      }
    },
    {
      "name": "Logout",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": ""
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/logout",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "logout"]
        }
      }
    },
    {
      "name": "Error Cases",
      "item": [
        {
          "name": "Duplicate Email",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// {{testEmail}} was registered in step 1 — re-registering must return 409.",
                  "pm.test('status 409 - Duplicate Email', function () {",
                  "    pm.response.to.have.status(409);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\",\n  \"fullName\": \"Dev One\",\n  \"role\": \"patient\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Re-registers the same email created in step 1 → 409 Conflict."
          }
        },
        {
          "name": "Wrong Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 401 - Wrong Password', function () {",
                  "    pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"WrongPass999\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Correct email, wrong password → 401 Unauthorized."
          }
        },
        {
          "name": "No Token - Get Me",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 401 - No Token', function () {",
                  "    pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            },
            "description": "No Authorization header → 401 Unauthorized."
          }
        },
        {
          "name": "Weak Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// express-validator returns 422 Unprocessable Entity for validation failures.",
                  "// The backend uses assertValid() which sets err.status = 422, not 400.",
                  "pm.test('status 422 - Weak Password (validation error)', function () {",
                  "    pm.response.to.have.status(422);",
                  "});",
                  "",
                  "pm.test('response has validation errors array', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('errors');",
                  "    pm.expect(json.errors).to.be.an('array').that.is.not.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"weakpass@surakshahealth.com\",\n  \"password\": \"abc\",\n  \"fullName\": \"Weak User\",\n  \"role\": \"patient\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Password 'abc' is < 8 chars → express-validator returns 422 with errors array."
          }
        },
        {
          "name": "Missing Fields",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// express-validator returns 422 Unprocessable Entity for validation failures.",
                  "pm.test('status 422 - Missing Fields (validation error)', function () {",
                  "    pm.response.to.have.status(422);",
                  "});",
                  "",
                  "pm.test('response has validation errors array', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('errors');",
                  "    pm.expect(json.errors).to.be.an('array').that.is.not.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Empty body → express-validator returns 422 with errors array listing all missing required fields."
          }
        }
      ]
    }
  ],
  "variable": []
}
